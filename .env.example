# ==================================================
# Alumni Influencers - Environment Variables
# ==================================================

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=alumni_influencers

# Application
PORT=3000

# Session secret (use a long random string)
SESSION_SECRET=your-very-long-random-session-secret-here

# JWT secret for API token signing
JWT_SECRET=your-very-long-random-jwt-secret-here

# Allowed email domain for registration
ALLOWED_EMAIL_DOMAIN=eastminster.ac.uk