<!DOCTYPE html>
<html>
<head>
    <title>Create Profile - Alumni Influencers</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 700px; margin: 40px auto; padding: 0 20px; }
        .error { color: red; margin-bottom: 10px; }
        label { display: block; margin-top: 10px; font-weight: bold; }
        input, textarea { width: 100%; padding: 8px; margin-top: 4px; box-sizing: border-box; }
        textarea { height: 120px; }
        button { margin-top: 20px; padding: 10px 20px; background: #2563eb; color: white; border: none; cursor: pointer; }
        button:hover { background: #1d4ed8; }
        nav { margin-bottom: 20px; }
        nav a { margin-right: 15px; }
    </style>
</head>
<body>
    <nav>
        <a href="/profile">Profile</a>
        <a href="/bids">Bids</a>
        <a href="/api-keys">API Keys</a>
        <form method="POST" action="/logout" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" style="background:none;color:#2563eb;border:none;cursor:pointer;padding:0;">Logout</button>
        </form>
    </nav>

    <h1>Create Your Alumni Profile</h1>

    <% if (errors && errors.length > 0) { %>
        <div class="error">
            <ul>
                <% errors.forEach(function(err) { %>
                    <li><%= err %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <form method="POST" action="/profile/create" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <label>Biography</label>
        <textarea name="biography" placeholder="Tell us about yourself..."></textarea>

        <label>LinkedIn URL</label>
        <input type="url" name="linkedin_url" placeholder="https://linkedin.com/in/yourprofile">

        <label>Profile Image</label>
        <input type="file" name="profile_image" accept="image/*">

        <button type="submit">Create Profile</button>
    </form>

    <p>You can add degrees, certifications, and more after creating your profile.</p>
</body>
</html>