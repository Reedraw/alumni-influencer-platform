<!DOCTYPE html>
<html>
<head>
    <title>Edit Profile - Alumni Influencers</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 800px; margin: 40px auto; padding: 0 20px; }
        .error { color: red; margin-bottom: 10px; }
        label { display: block; margin-top: 10px; font-weight: bold; }
        input, textarea, select { width: 100%; padding: 8px; margin-top: 4px; box-sizing: border-box; }
        textarea { height: 100px; }
        button { padding: 8px 16px; cursor: pointer; margin-top: 5px; }
        .btn-primary { background: #2563eb; color: white; border: none; }
        .btn-danger { background: #dc2626; color: white; border: none; }
        .btn-secondary { background: #6b7280; color: white; border: none; }
        .section { margin: 30px 0; border: 1px solid #e5e7eb; padding: 20px; border-radius: 8px; }
        .section h2 { margin-top: 0; }
        .item { background: #f9fafb; padding: 12px; margin: 8px 0; border-radius: 6px; display: flex; justify-content: space-between; align-items: center; }
        .item-content { flex: 1; }
        .item-actions { display: flex; gap: 8px; }
        .add-form { background: #f0f9ff; padding: 15px; border-radius: 8px; margin-top: 15px; }
        nav { margin-bottom: 20px; }
        nav a { margin-right: 15px; }
    </style>
</head>
<body>
    <nav>
        <a href="/profile">Profile</a>
        <a href="/bids">Bids</a>
        <a href="/api-keys">API Keys</a>
        <form method="POST" action="/logout" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" style="background:none;color:#2563eb;border:none;cursor:pointer;padding:0;">Logout</button>
        </form>
    </nav>

    <h1>Edit Profile</h1>

    <% if (errors && errors.length > 0) { %>
        <div class="error">
            <ul>
                <% errors.forEach(function(err) { %>
                    <li><%= err %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <!-- Main Profile -->
    <div class="section">
        <h2>Profile Information</h2>
        <form method="POST" action="/profile/edit">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <label>Biography</label>
            <textarea name="biography"><%= profile.biography || '' %></textarea>
            <label>LinkedIn URL</label>
            <input type="url" name="linkedin_url" value="<%= profile.linkedin_url || '' %>">
            <button type="submit" class="btn-primary">Update Profile</button>
        </form>
    </div>

    <!-- Profile Image -->
    <div class="section">
        <h2>Profile Image</h2>
        <% if (profile.profile_image_path) { %>
            <img src="/<%= profile.profile_image_path %>" alt="Profile" style="width:100px;height:100px;border-radius:50%;object-fit:cover;">
        <% } %>
        <form method="POST" action="/profile/image" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="file" name="profile_image" accept="image/*" required>
            <button type="submit" class="btn-primary">Upload Image</button>
        </form>
    </div>

    <!-- Degrees -->
    <div class="section">
        <h2>Degrees</h2>
        <% if (profile.degrees && profile.degrees.length > 0) { %>
            <% profile.degrees.forEach(function(d) { %>
                <div class="item">
                    <div class="item-content">
                        <strong><%= d.degree_name %></strong>
                        <% if (d.institution_name) { %> - <%= d.institution_name %><% } %>
                        <% if (d.completion_date) { %> (<%= new Date(d.completion_date).toLocaleDateString() %>)<% } %>
                    </div>
                    <div class="item-actions">
                        <a href="/profile/edit?editDegree=<%= d.id %>"><button class="btn-secondary">Edit</button></a>
                        <form method="POST" action="/profile/degrees/<%= d.id %>/delete" style="display:inline;">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } %>
        <div class="add-form">
            <h3><%= editDegree ? 'Edit Degree' : 'Add Degree' %></h3>
            <form method="POST" action="<%= editDegree ? '/profile/degrees/' + editDegree.id + '/edit' : '/profile/degrees/add' %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label>Degree Name *</label>
                <input type="text" name="degree_name" required value="<%= editDegree ? editDegree.degree_name : '' %>">
                <label>Institution</label>
                <input type="text" name="institution_name" value="<%= editDegree ? (editDegree.institution_name || '') : '' %>">
                <label>Degree URL</label>
                <input type="url" name="degree_url" value="<%= editDegree ? (editDegree.degree_url || '') : '' %>">
                <label>Completion Date</label>
                <input type="date" name="completion_date" value="<%= editDegree && editDegree.completion_date ? new Date(editDegree.completion_date).toISOString().split('T')[0] : '' %>">
                <button type="submit" class="btn-primary"><%= editDegree ? 'Update' : 'Add' %> Degree</button>
                <% if (editDegree) { %><a href="/profile/edit"><button type="button" class="btn-secondary">Cancel</button></a><% } %>
            </form>
        </div>
    </div>

    <!-- Certifications -->
    <div class="section">
        <h2>Certifications</h2>
        <% if (profile.certifications && profile.certifications.length > 0) { %>
            <% profile.certifications.forEach(function(c) { %>
                <div class="item">
                    <div class="item-content">
                        <strong><%= c.certification_name %></strong>
                        <% if (c.provider_name) { %> - <%= c.provider_name %><% } %>
                        <% if (c.completion_date) { %> (<%= new Date(c.completion_date).toLocaleDateString() %>)<% } %>
                    </div>
                    <div class="item-actions">
                        <a href="/profile/edit?editCertification=<%= c.id %>"><button class="btn-secondary">Edit</button></a>
                        <form method="POST" action="/profile/certifications/<%= c.id %>/delete" style="display:inline;">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } %>
        <div class="add-form">
            <h3><%= editCertification ? 'Edit Certification' : 'Add Certification' %></h3>
            <form method="POST" action="<%= editCertification ? '/profile/certifications/' + editCertification.id + '/edit' : '/profile/certifications/add' %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label>Certification Name *</label>
                <input type="text" name="certification_name" required value="<%= editCertification ? editCertification.certification_name : '' %>">
                <label>Provider</label>
                <input type="text" name="provider_name" value="<%= editCertification ? (editCertification.provider_name || '') : '' %>">
                <label>Course URL</label>
                <input type="url" name="course_url" value="<%= editCertification ? (editCertification.course_url || '') : '' %>">
                <label>Completion Date</label>
                <input type="date" name="completion_date" value="<%= editCertification && editCertification.completion_date ? new Date(editCertification.completion_date).toISOString().split('T')[0] : '' %>">
                <button type="submit" class="btn-primary"><%= editCertification ? 'Update' : 'Add' %> Certification</button>
                <% if (editCertification) { %><a href="/profile/edit"><button type="button" class="btn-secondary">Cancel</button></a><% } %>
            </form>
        </div>
    </div>

    <!-- Licences -->
    <div class="section">
        <h2>Professional Licences</h2>
        <% if (profile.licences && profile.licences.length > 0) { %>
            <% profile.licences.forEach(function(l) { %>
                <div class="item">
                    <div class="item-content">
                        <strong><%= l.licence_name %></strong>
                        <% if (l.awarding_body_name) { %> - <%= l.awarding_body_name %><% } %>
                        <% if (l.completion_date) { %> (<%= new Date(l.completion_date).toLocaleDateString() %>)<% } %>
                    </div>
                    <div class="item-actions">
                        <a href="/profile/edit?editLicence=<%= l.id %>"><button class="btn-secondary">Edit</button></a>
                        <form method="POST" action="/profile/licences/<%= l.id %>/delete" style="display:inline;">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } %>
        <div class="add-form">
            <h3><%= editLicence ? 'Edit Licence' : 'Add Licence' %></h3>
            <form method="POST" action="<%= editLicence ? '/profile/licences/' + editLicence.id + '/edit' : '/profile/licences/add' %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label>Licence Name *</label>
                <input type="text" name="licence_name" required value="<%= editLicence ? editLicence.licence_name : '' %>">
                <label>Awarding Body</label>
                <input type="text" name="awarding_body_name" value="<%= editLicence ? (editLicence.awarding_body_name || '') : '' %>">
                <label>Awarding Body URL</label>
                <input type="url" name="awarding_body_url" value="<%= editLicence ? (editLicence.awarding_body_url || '') : '' %>">
                <label>Completion Date</label>
                <input type="date" name="completion_date" value="<%= editLicence && editLicence.completion_date ? new Date(editLicence.completion_date).toISOString().split('T')[0] : '' %>">
                <button type="submit" class="btn-primary"><%= editLicence ? 'Update' : 'Add' %> Licence</button>
                <% if (editLicence) { %><a href="/profile/edit"><button type="button" class="btn-secondary">Cancel</button></a><% } %>
            </form>
        </div>
    </div>

    <!-- Short Courses -->
    <div class="section">
        <h2>Short Courses</h2>
        <% if (profile.shortCourses && profile.shortCourses.length > 0) { %>
            <% profile.shortCourses.forEach(function(c) { %>
                <div class="item">
                    <div class="item-content">
                        <strong><%= c.course_name %></strong>
                        <% if (c.provider_name) { %> - <%= c.provider_name %><% } %>
                        <% if (c.completion_date) { %> (<%= new Date(c.completion_date).toLocaleDateString() %>)<% } %>
                    </div>
                    <div class="item-actions">
                        <a href="/profile/edit?editShortCourse=<%= c.id %>"><button class="btn-secondary">Edit</button></a>
                        <form method="POST" action="/profile/courses/<%= c.id %>/delete" style="display:inline;">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } %>
        <div class="add-form">
            <h3><%= editShortCourse ? 'Edit Course' : 'Add Course' %></h3>
            <form method="POST" action="<%= editShortCourse ? '/profile/courses/' + editShortCourse.id + '/edit' : '/profile/courses/add' %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label>Course Name *</label>
                <input type="text" name="course_name" required value="<%= editShortCourse ? editShortCourse.course_name : '' %>">
                <label>Provider</label>
                <input type="text" name="provider_name" value="<%= editShortCourse ? (editShortCourse.provider_name || '') : '' %>">
                <label>Course URL</label>
                <input type="url" name="course_url" value="<%= editShortCourse ? (editShortCourse.course_url || '') : '' %>">
                <label>Completion Date</label>
                <input type="date" name="completion_date" value="<%= editShortCourse && editShortCourse.completion_date ? new Date(editShortCourse.completion_date).toISOString().split('T')[0] : '' %>">
                <button type="submit" class="btn-primary"><%= editShortCourse ? 'Update' : 'Add' %> Course</button>
                <% if (editShortCourse) { %><a href="/profile/edit"><button type="button" class="btn-secondary">Cancel</button></a><% } %>
            </form>
        </div>
    </div>

    <!-- Employment History -->
    <div class="section">
        <h2>Employment History</h2>
        <% if (profile.employment && profile.employment.length > 0) { %>
            <% profile.employment.forEach(function(e) { %>
                <div class="item">
                    <div class="item-content">
                        <strong><%= e.job_title %></strong> at <%= e.employer_name %>
                        <% if (e.is_current_role) { %><span style="color:#10b981;font-weight:bold;"> (Current)</span><% } %>
                        <% if (e.start_date) { %><br>From: <%= new Date(e.start_date).toLocaleDateString() %><% } %>
                        <% if (e.end_date) { %> - To: <%= new Date(e.end_date).toLocaleDateString() %><% } %>
                    </div>
                    <div class="item-actions">
                        <a href="/profile/edit?editEmployment=<%= e.id %>"><button class="btn-secondary">Edit</button></a>
                        <form method="POST" action="/profile/employment/<%= e.id %>/delete" style="display:inline;">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
            <% }); %>
        <% } %>
        <div class="add-form">
            <h3><%= editEmployment ? 'Edit Employment' : 'Add Employment' %></h3>
            <form method="POST" action="<%= editEmployment ? '/profile/employment/' + editEmployment.id + '/edit' : '/profile/employment/add' %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label>Employer Name *</label>
                <input type="text" name="employer_name" required value="<%= editEmployment ? editEmployment.employer_name : '' %>">
                <label>Job Title *</label>
                <input type="text" name="job_title" required value="<%= editEmployment ? editEmployment.job_title : '' %>">
                <label>Start Date</label>
                <input type="date" name="start_date" value="<%= editEmployment && editEmployment.start_date ? new Date(editEmployment.start_date).toISOString().split('T')[0] : '' %>">
                <label>End Date</label>
                <input type="date" name="end_date" value="<%= editEmployment && editEmployment.end_date ? new Date(editEmployment.end_date).toISOString().split('T')[0] : '' %>">
                <label><input type="checkbox" name="is_current_role" <%= editEmployment && editEmployment.is_current_role ? 'checked' : '' %>> Current Role</label>
                <label>Description</label>
                <textarea name="description"><%= editEmployment ? (editEmployment.description || '') : '' %></textarea>
                <button type="submit" class="btn-primary"><%= editEmployment ? 'Update' : 'Add' %> Employment</button>
                <% if (editEmployment) { %><a href="/profile/edit"><button type="button" class="btn-secondary">Cancel</button></a><% } %>
            </form>
        </div>
    </div>

    <p><a href="/profile">Back to Profile</a></p>
</body>
</html>