<!DOCTYPE html>
<html>
<head>
    <title>Place Bid - Alumni Influencers</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 500px; margin: 40px auto; padding: 0 20px; }
        .error { color: red; margin-bottom: 10px; }
        .info { background: #eff6ff; border: 1px solid #bfdbfe; padding: 15px; border-radius: 8px; margin-bottom: 20px; }
        .warning { background: #fffbeb; border: 1px solid #fed7aa; padding: 15px; border-radius: 8px; margin-bottom: 20px; }
        label { display: block; margin-top: 10px; font-weight: bold; }
        input { width: 100%; padding: 8px; margin-top: 4px; box-sizing: border-box; }
        button { margin-top: 20px; padding: 10px 20px; background: #2563eb; color: white; border: none; cursor: pointer; }
        button:hover { background: #1d4ed8; }
        nav { margin-bottom: 20px; }
        nav a { margin-right: 15px; }
    </style>
</head>
<body>
    <nav>
        <a href="/profile">Profile</a>
        <a href="/bids">Bids</a>
        <a href="/api-keys">API Keys</a>
        <form method="POST" action="/logout" style="display:inline;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" style="background:none;color:#2563eb;border:none;cursor:pointer;padding:0;">Logout</button>
        </form>
    </nav>

    <h1><%= existingBid ? 'Update Your Bid' : 'Place a Bid' %></h1>

    <div class="info">
        <p><strong>Bidding Cycle:</strong> <%= cycle.cycle_date %></p>
        <p><strong>Monthly Features:</strong> <%= winCount %> / <%= monthlyLimit %> used</p>
        <p>This is a <strong>blind bidding</strong> system. You cannot see other bids.</p>
    </div>

    <% if (!canBid) { %>
        <div class="warning">
            <p>You have reached your monthly feature limit and cannot bid.</p>
        </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
        <div class="error">
            <ul>
                <% errors.forEach(function(err) { %>
                    <li><%= err %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <% if (canBid) { %>
        <% if (existingBid) { %>
            <div class="info">
                <p>Your current bid: <strong>&pound;<%= parseFloat(existingBid.current_bid_amount).toFixed(2) %></strong></p>
                <p>You can only increase your bid.</p>
            </div>
            <form method="POST" action="/bids/update">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label>New Bid Amount (&pound;)</label>
                <input type="number" name="amount" step="0.01" min="0.01" required
                       placeholder="Enter amount higher than current bid">
                <button type="submit">Update Bid</button>
            </form>
        <% } else { %>
            <form method="POST" action="/bids/place">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label>Bid Amount (&pound;)</label>
                <input type="number" name="amount" step="0.01" min="0.01" required
                       placeholder="Enter your bid amount">
                <button type="submit">Place Bid</button>
            </form>
        <% } %>
    <% } %>

    <p><a href="/bids">Back to Bids</a></p>
</body>
</html>