<!DOCTYPE html>
<html>
<head>
    <title>Reset Password - Alumni Influencers</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 500px; margin: 40px auto; padding: 0 20px; }
        .error { color: red; margin-bottom: 10px; }
        label { display: block; margin-top: 10px; font-weight: bold; }
        input { width: 100%; padding: 8px; margin-top: 4px; box-sizing: border-box; }
        button { margin-top: 20px; padding: 10px 20px; background: #2563eb; color: white; border: none; cursor: pointer; }
        button:hover { background: #1d4ed8; }
        .help { font-size: 0.85em; color: #666; }
    </style>
</head>
<body>
    <h1>Reset Password</h1>

    <% if (errors && errors.length > 0) { %>
        <div class="error">
            <ul>
                <% errors.forEach(function(err) { %>
                    <li><%= err %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <form method="POST" action="/reset-password">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="token" value="<%= token %>">

        <label>New Password</label>
        <input type="password" name="password" required minlength="8">
        <p class="help">Min 8 chars, uppercase, lowercase, number, special character</p>

        <label>Confirm Password</label>
        <input type="password" name="confirm_password" required>

        <button type="submit">Reset Password</button>
    </form>
</body>
</html>